/* Combos e inputs genéricos del formulario combinado */
QComboBox {
    height: 40px;
    font-size: 15px;
    padding: 4px 8px;
    border: 1px solid #d2d2d2;
    border-radius: 4px;
}
QComboBox:hover {
    background-color: #f1f5f9;
}

QLineEdit {
    font-size: 15px;
    padding: 4px 8px;
    background-color: #f1f5f9;
    color: #647790;
    font-weight: bold;
    border: 1px solid #d2d2d2;
    border-radius: 4px;
}
