QComboBox QAbstractItemView::item {
    min-height: 30px;
    padding: 4px 8px;
}

QCheckBox#ChkPapeleria {
    background: transparent;
    border: none;
    spacing: 0px;
    padding: 0px;
    min-height: 34px; 
}

/* Cajita sin marcar (Gris suave) */
QCheckBox#ChkPapeleria::indicator {
    width: 24px;
    height: 24px;
    subcontrol-position: center;
    
    background-color: white;
    border: 2px solid #d1d5db;
    border-radius: 5px;
}

/* Sin efectos hover en la caja */
QCheckBox#ChkPapeleria:hover,
QCheckBox#ChkPapeleria::indicator:hover {
    background: transparent;
    border-color: #d1d5db; 
}

/* Estado MARCADO (Checked) */
QCheckBox#ChkPapeleria::indicator:checked {
    background-color: white;
    border: 1px solid #3b82f6; /* Borde azul */
    
    /* Usamos la variable que inyectamos desde Python */
    image: url(%(ASSETS_DIR)s/icons/check.svg);
}