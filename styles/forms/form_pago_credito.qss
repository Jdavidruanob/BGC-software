/* Combos específicos del formulario */
#ComboRecibiDe, #ComboSocioPago {
    height: 40px;
    font-size: 15px;
    padding: 4px 8px;
    border: 1px solid #d2d2d2;
    border-radius: 4px;
}
#ComboRecibiDe:hover, #ComboSocioPago:hover {
    background-color: #f1f5f9;
}

#CuotasInput, #AbonoInput {
    font-size: 15px;
    padding: 4px 8px;
    background-color: #f1f5f9;
    color: #647790;
    font-weight: bold;
    border: 1px solid #d2d2d2;
    border-radius: 4px;
}
